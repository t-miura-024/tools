    "globby": "^16.2.0",
    "pathe": "^2.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "tsx": "^4.22.0",
